{
  "project_id": "xtl-api",
  "project_name": "XTL API",
  "openapi": {
    "mode": "file",
    "value": "openapi.json"
  },
  "environments": {
    "staging": {
      "base_url": "https://app.xautrendlab.com"
    }
  },
  "defaults": {
    "default_env": "staging",
    "default_auth_profile": "device",
    "default_headers": {
      "Accept": "application/json"
    }
  },
  "auth_profiles": [
    {
      "name": "device",
      "type": "header",
      "headers": {
        "X-Device-Id": "{{DEVICE_ID}}"
      }
    }
  ]
}
